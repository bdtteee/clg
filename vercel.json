{
  "version": 2,
  "installCommand": "npm install -g pnpm@latest && pnpm install --frozen-lockfile",
  "buildCommand": "BASE_PATH=/ pnpm --filter @workspace/cardone-loans run build && pnpm --filter @workspace/api-server run build",
  "outputDirectory": "artifacts/cardone-loans/dist/public",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
