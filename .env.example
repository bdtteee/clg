# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard > Settings > Database > Connection string

# Session-mode pooler (port 5432) – used at runtime by the API
DATABASE_URL=postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Transaction-mode pooler (port 6543) – used at runtime on Render
POSTGRES_URL=postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Direct connection (port 5432) – used only for drizzle migrations
POSTGRES_URL_NON_POOLING=postgresql://postgres.[PROJECT]:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── Supabase ─────────────────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Get from: Supabase Dashboard > Settings > API > JWT Settings > JWT Secret
# This is used to sign and verify auth tokens
SUPABASE_JWT_SECRET=

# ── Auth / Session ────────────────────────────────────────────
# Session secret for express-session (use a strong random value in production)
SESSION_SECRET=change-me-in-production

# ── App ────────────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── CORS ───────────────────────────────────────────────────────────────────────────────────
# Allowed frontend origin(s) for cross-origin auth. Comma-separate for multiple.
# The production domains (cardoneloansgrants.org) and *.vercel.app deploys are
# always allowed by the server, so this only needs custom/extra origins.
# Development: http://localhost:5173 · Production: https://cardoneloansgrants.org
FRONTEND_URL=https://cardoneloansgrants.org

# ── Split Deploy (Render backend + Vercel frontend) ─────────────────────────────────────
# Set this in your Vercel project environment variables to tell the frontend
# where the Render API is. Leave blank for monolithic Vercel deploy.
# VITE_API_URL=https://clg-6ngl.onrender.com
# VITE_SUPABASE_URL=https://[PROJECT].supabase.co
# VITE_SUPABASE_ANON_KEY=[your-anon-key]

# ── SMTP (email notifications) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@cardoneloansgrants.org

# ── M-Pesa ─────────────────────────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=4167853
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://cardoneloansgrants.org/api/payments/mpesa/callback
MPESA_ENV=production
